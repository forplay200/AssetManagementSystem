const express = require('express');
const router = express.Router();
const { uploadAsset, downloadAsset, deleteAsset, previewAsset, getAssetMetadata, updateAssetMetadata, addTagToAsset, removeTagFromAsset, getAssetTags, createVersion, getVersionHistory, getVersion, downloadVersion, searchAssets } = require("../controllers/assetsController");
const auth = require('../middleware/auth');
const rbac = require('../middleware/rbac');

// POST /api/assets/upload
router.post('/upload', auth, rbac('admin', 'developer', 'designer', 'collaborator'), uploadAsset);

// GET /api/assets/download/:id
router.get('/download/:id', auth, rbac('admin', 'developer', 'designer', 'collaborator'), downloadAsset);

// GET /api/assets/preview/:id
router.get('/preview/:id', auth, rbac('admin', 'developer', 'designer', 'collaborator'), previewAsset);

// GET /api/assets/:id/metadata
router.get('/:id/metadata', auth, rbac('admin', 'developer', 'designer', 'collaborator'), getAssetMetadata);

// PUT /api/assets/:id/metadata
router.put('/:id/metadata', auth, rbac('admin', 'developer', 'designer', 'collaborator'), updateAssetMetadata);

// POST /api/assets/:assetId/tags/:tagId
router.post('/:assetId/tags/:tagId', auth, rbac('admin', 'developer', 'designer', 'collaborator'), addTagToAsset);

// DELETE /api/assets/:assetId/tags/:tagId
router.delete('/:assetId/tags/:tagId', auth, rbac('admin', 'developer', 'designer', 'collaborator'), removeTagFromAsset);

// GET /api/assets/:assetId/tags
router.get('/:assetId/tags', auth, rbac('admin', 'developer', 'designer', 'collaborator'), getAssetTags);

// Version control routes
// POST /api/assets/:id/versions
router.post('/:id/versions', auth, rbac('admin', 'developer', 'designer', 'collaborator'), createVersion);
// GET /api/assets/:id/versions
router.get('/:id/versions', auth, rbac('admin', 'developer', 'designer', 'collaborator'), getVersionHistory);
// GET /api/assets/:id/versions/:versionId
router.get('/:id/versions/:versionId', auth, rbac('admin', 'developer', 'designer', 'collaborator'), getVersion);
// GET /api/assets/:id/versions/:versionId/download
router.get('/:id/versions/:versionId/download', auth, rbac('admin', 'developer', 'designer', 'collaborator'), downloadVersion);

// DELETE /api/assets/:id
router.delete('/:id', auth, rbac('admin', 'developer', 'designer', 'collaborator'), deleteAsset);

router.get('/search', auth, rbac('admin', 'developer', 'designer', 'collaborator'), searchAssets);




router.post('/ai/job', auth, rbac('admin', 'developer', 'designer', 'collaborator'), assetsController.createAiJob);
