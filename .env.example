# Environment variables template
# Copy this file to .env and fill in the values

# Backend
PORT=3000
JWT_SECRET=your_jwt_secret_here
DATABASE_URL=postgres://user:password@localhost:5432/db
# Security compatibility switch. Keep false so public registration always creates Collaborators.
ALLOW_PUBLIC_ROLE_REGISTRATION=false

# Frontend (if using Create React App)
REACT_APP_API_URL=http://localhost:3000/api

# AI Service
AI_PORT=8000
AI_HOST=0.0.0.0

# Database (if using PostgreSQL via Docker)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
